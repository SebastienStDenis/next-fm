# Copy to .env to override defaults or provide secrets; docker compose reads it
# automatically. Everything below is optional - the defaults work out of the box.
# POSTGRES_PASSWORD is interpolated into DATABASE_URL, so keep it URL-safe
# (letters, digits, - _ . ~) or URL-encode it yourself.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app

# Secrets (API keys etc.) go here too, uncommitted. Reference them in
# docker-compose.yml without a default so a missing value fails loudly:
#   SOME_API_KEY: ${SOME_API_KEY:?set SOME_API_KEY in .env}
