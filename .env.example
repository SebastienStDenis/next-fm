# App data lives in the Supabase CLI stack (supabase start); these creds are
# its local defaults.
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:54322/postgres
# Set true only when DATABASE_URL points at Supabase's transaction-mode pooler
# (port 6543); leave false for the session-mode pooler, direct connections, or
# local Postgres.
DATABASE_DISABLE_PREPARED_STATEMENTS=false
LASTFM_API_KEY=
BANDSINTOWN_API_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# From the one-time bot-account authorization: uv run python -m app.spotify_auth
SPOTIFY_REFRESH_TOKEN=
# Temporal: defaults target the docker-compose server; in production point these
# at Temporal Cloud (address, namespace, API key) - no other change is needed.
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=user-sync
TEMPORAL_API_KEY=
# Comma-separated list of browser origins allowed by CORS. In production this
# is the Vercel frontend origin; locally the Next dev server.
CORS_ORIGINS=http://localhost:3000

# Supabase (local CLI stack values; swap for the hosted project's values in
# production). SUPABASE_JWT_SECRET verifies HS256 tokens - the local stack
# signs with it; leave it unset in production if the hosted project uses
# asymmetric JWT signing keys (the backend then verifies via JWKS).
# SUPABASE_SECRET_KEY authorizes the GoTrue admin API (account deletion); copy
# the sb_secret_... value from `supabase status` (an sb_secret literal in the
# repo, even the CLI's default, trips GitHub push protection).
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
SUPABASE_SECRET_KEY=
# The frontend's key (safe to expose; compose passes it to the web container).
SUPABASE_PUBLISHABLE_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH
