# Copy to .env and fill in the required section. Everything else has working
# local defaults: leave those lines commented unless you need a different
# value, so your .env stays a list of secrets and deliberate overrides.

# --- Required secrets (compose refuses to start without them) ---

LASTFM_API_KEY=
BANDSINTOWN_API_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# From the one-time bot-account authorization: uv run python -m cli.spotify_auth
SPOTIFY_REFRESH_TOKEN=

# --- Supabase auth (local CLI values; swap for the hosted project's in prod) ---

# Verifies HS256 tokens - the local stack signs with it; leave it unset in
# production if the hosted project uses asymmetric JWT signing keys (the
# backend then verifies via JWKS).
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
# Authorizes the GoTrue admin API (account deletion); copy the sb_secret_...
# value from `supabase status` (an sb_secret literal in the repo, even the
# CLI's default, trips GitHub push protection).
SUPABASE_SECRET_KEY=

# --- Optional overrides (defaults shown; uncomment to change) ---

# App data lives in the Supabase CLI stack (supabase start); this is its local
# default. In production point it at the hosted project's pooler.
# DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:54322/postgres

# Set true only when DATABASE_URL points at Supabase's transaction-mode pooler
# (port 6543); leave false for the session-mode pooler, direct connections, or
# local Postgres.
# DATABASE_DISABLE_PREPARED_STATEMENTS=false

# Temporal: defaults target the docker-compose server; in production point these
# at Temporal Cloud (address, namespace, API key) - no other change is needed.
# TEMPORAL_ADDRESS=localhost:7233
# TEMPORAL_NAMESPACE=default
# TEMPORAL_TASK_QUEUE=user-sync
# TEMPORAL_API_KEY=

# The worker keeps the nightly re-sync schedule only when true (and deletes it
# when false); leave false locally, set true in production.
# NIGHTLY_SYNC_ENABLED=false

# Error reporting. Unset (the local default) disables Sentry entirely and logs
# only to the console. In production both the api and worker services take the
# same backend DSN from the Render env group; the `component` tag tells their
# events apart. RENDER_GIT_COMMIT is set by Render itself and needs no entry.
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
# LOG_LEVEL=INFO

# Comma-separated list of browser origins allowed by CORS. In production this
# is the Vercel frontend origin; locally the Next dev server.
# CORS_ORIGINS=http://localhost:3000

# SUPABASE_URL=http://127.0.0.1:54321

# The frontend's key (safe to expose; compose passes it to the web container).
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH
