POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/app
# Set true only when DATABASE_URL points at Supabase's transaction-mode pooler
# (port 6543); leave false for the session-mode pooler, direct connections, or
# local Postgres.
DATABASE_DISABLE_PREPARED_STATEMENTS=false
LASTFM_API_KEY=
BANDSINTOWN_API_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# From the one-time bot-account authorization: uv run python -m app.spotify_auth
SPOTIFY_REFRESH_TOKEN=
# Temporal: defaults target the docker-compose server; in production point these
# at Temporal Cloud (address, namespace, API key) - no other change is needed.
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=user-sync
TEMPORAL_API_KEY=
# Comma-separated list of browser origins allowed by CORS. In production this
# is the Vercel frontend origin; locally the Next dev server.
CORS_ORIGINS=http://localhost:3000
